# ═══════════════════════════════════════════════════════
# CONFIGURACIÓN - Backend Telemetría FS25
# Copia este archivo a .env y ajusta los valores
# ═══════════════════════════════════════════════════════

# Environment
NODE_ENV=development

# WebSocket / Socket.io
SOCKET_IO_PORT=8080
SOCKET_IO_PATH=/socket.io
SOCKET_IO_NAMESPACE=/telemetry
CORS_ORIGIN=http://localhost:8080

# Named Pipe (FSTelemetry.lua)
NAMED_PIPE_NAME=\\\\.\\pipe\\SHTelemetry
NAMED_PIPE_TIMEOUT=5000
NAMED_PIPE_ENCODING=utf8

# Configuración de Datos
UPDATE_FREQUENCY_MS=16.66
MAX_BUFFER_SIZE=1000
DEBUG_MODE=false

# Logs
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
